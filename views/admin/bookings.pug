extends ../layout-admin

block content
  .page-header
    h2 Manajemen Pemesanan
    p Lihat dan kelola semua pemesanan pelanggan
    div(style="margin-top: 15px;")
      a.btn.btn-primary(href="/admin/bookings/new") + Tambah Pemesanan Offline

  .card
    if bookings && bookings.length
      .table-wrapper
        table
          thead
            tr
              th ID
              th Email User
              th Nama Penumpang
              th Rute
              th Kursi
              th Status
              th Tanggal
              th Aksi
          tbody
            each b in bookings
              tr
                td #{b.id}
                td #{b.email}
                td #{b.passenger_name || '-'}
                td #{b.origin} → #{b.destination}
                td #{b.seat_number}
                td
                  if b.status === 'pending'
                    span.badge.badge-pending Pending
                  else if b.status === 'confirmed'
                    span.badge.badge-confirmed Confirmed
                  else if b.status === 'cancelled'
                    span.badge.badge-canceled Cancelled
                  else if b.status === 'refunded'
                    span.badge.badge-refunded Refunded
                td #{new Date(b.created_at).toLocaleString('id-ID')}
                td
                  .actions
                    if b.status === 'pending'
                      form(method="POST" action=`/admin/bookings/status/${b.id}`)
                        input(type="hidden" name="status" value="confirmed")
                        button.btn.btn-success.btn-sm(type="submit") Konfirmasi
                      form(method="POST" action=`/admin/bookings/status/${b.id}`)
                        input(type="hidden" name="status" value="cancelled")
                        button.btn.btn-danger.btn-sm(type="submit") Batalkan
                    if b.status === 'confirmed' || b.status === 'pending'
                      a.btn.btn-secondary.btn-sm(href=`/admin/bookings/reschedule/${b.id}`) Reschedule
                    if b.status === 'confirmed'
                      a.btn.btn-primary.btn-sm(href=`/admin/eticket/${b.id}`) QR Ticket
                      form(method="POST" action=`/admin/bookings/status/${b.id}`)
                        input(type="hidden" name="status" value="refunded")
                        button.btn.btn-warning.btn-sm(type="submit") Refund
    else
      .empty-state
        h3 Belum ada pemesanan
        p Pemesanan akan muncul di sini ketika pelanggan melakukan booking

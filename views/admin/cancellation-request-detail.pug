extends ../layout-admin

block content
  .page-header
    h2 Detail Permintaan Pembatalan
    p Request ID: #{request.request_id}

  .detail-grid
    .detail-card
      h4 Informasi Pemesanan
      .detail-row
        span.detail-label Kode Booking
        span.detail-value #{request.booking_code}
      .detail-row
        span.detail-label Status Pemesanan
        span.detail-value #{request.booking_status}
      .detail-row
        span.detail-label Nama Penumpang
        span.detail-value #{request.passenger_name}
      .detail-row
        span.detail-label Rute
        span.detail-value #{request.origin_city} → #{request.destination_city}
      .detail-row
        span.detail-label Keberangkatan
        span.detail-value #{new Date(request.departure_time).toLocaleString('id-ID')}

    .detail-card
      h4 Detail Permintaan
      .detail-row
        span.detail-label Status
        span.detail-value
          if request.status === 'pending'
            span.badge.badge-pending Menunggu
          else if request.status === 'approved'
            span.badge.badge-confirmed Disetujui
          else
            span.badge.badge-canceled Ditolak
      .detail-row
        span.detail-label Diajukan Pada
        span.detail-value #{new Date(request.requested_at).toLocaleString('id-ID')}
      if request.reason
        .detail-row
          span.detail-label Alasan
          span.detail-value #{request.reason}

  if request.status === 'pending'
    .card(style="margin-top: 20px;")
      h4 Tindakan Admin
      form(method="POST" action=`/admin/cancellation-requests/${request.request_id}/approve`)
        .form-group
          label(for="admin_notes") Catatan Admin (opsional)
          textarea.form-control(name="admin_notes" rows="3" placeholder="Catatan untuk persetujuan...")
        div(style="margin-top: 15px;")
          button.btn.btn-success(type="submit" onclick="return confirm('Setujui permintaan pembatalan ini? Pemesanan akan dibatalkan.')") Setujui Pembatalan
      form(method="POST" action=`/admin/cancellation-requests/${request.request_id}/reject` style="margin-top: 10px;")
        .form-group
          label(for="admin_notes_reject") Alasan Penolakan
          textarea.form-control(name="admin_notes" rows="3" placeholder="Berikan alasan penolakan...")
        div(style="margin-top: 15px;")
          button.btn.btn-danger(type="submit" onclick="return confirm('Tolak permintaan pembatalan ini?')") Tolak Permintaan

  a.btn.btn-secondary(href="/admin/cancellation-requests" style="margin-top: 20px;") Kembali ke Daftar Permintaan

extends ../layout-customer

block content
  style.
    .table-wrapper table { border-collapse: separate; border-spacing: 0 15px; width: 100%; }
    .table-wrapper th, .table-wrapper td { padding: 18px 20px; vertical-align: middle; }
    .table-wrapper tbody tr { background: rgba(255, 255, 255, 0.03); box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
    .table-wrapper tbody tr td:first-child { border-top-left-radius: 12px; border-bottom-left-radius: 12px; }
    .table-wrapper tbody tr td:last-child { border-top-right-radius: 12px; border-bottom-right-radius: 12px; }
    .badge { white-space: nowrap; padding: 8px 14px; border-radius: 20px; font-size: 0.85em; font-weight: 500; }

  .page-header
    h2 Pesanan Saya
    p Kelola riwayat pemesanan tiket travel Anda
  
  .card(style="margin-top:20px;")
    if bookings && bookings.length
      .table-wrapper
        table
          thead
            tr
              th Kode
              th Rute
              th Berangkat
              th Kursi
              th Status
              th Total
              th Aksi
          tbody
            each b in bookings
              - const isPast = new Date() > new Date(b.departure_time);
              - const isUsedOrCancelled = b.status === 'cancelled' || b.status === 'expired' || (b.status === 'confirmed' && isPast);
              tr
                td <strong>#{b.booking_code}</strong>
                td #{b.origin_city} &rarr; #{b.destination_city}
                td #{new Date(b.departure_time).toLocaleString('id-ID')}
                td #{b.seat_numbers || '-'}
                td
                  if b.status === 'pending'
                    span.badge.badge-pending Menunggu Pembayaran
                  else if b.status === 'confirmed'
                    span.badge.badge-confirmed Lunas (E-Ticket Aktif)
                  else if b.status === 'expired'
                    span.badge.badge-canceled Kadaluarsa
                  else
                    span.badge.badge-canceled Dibatalkan
                td Rp #{Number(b.total_amount).toLocaleString('id-ID')}
                td
                  .actions(style="display: flex; gap: 10px; align-items: center;")
                    if b.status === 'pending'
                      a.btn.btn-success.btn-sm(href=`/customer/payment/${b.booking_id}`) Bayar
                      form(method="POST" action=`/customer/booking/${b.booking_id}/cancel` style="display:inline;")
                        button.btn.btn-danger.btn-sm(type="submit" style="padding: 8px 15px;") Batalkan
                    if b.status === 'confirmed' && !isPast
                      form(method="POST" action=`/customer/booking/${b.booking_id}/cancel` style="display:inline;")
                        button.btn.btn-warning.btn-sm(type="submit" onclick="return confirm('Anda yakin ingin membatalkan pesanan (Refund)?')" style="padding: 8px 15px;") Batalkan
                    if isUsedOrCancelled
                      form(method="POST" action=`/customer/booking/${b.booking_id}/delete` style="display:inline;")
                        button.btn.btn-danger.btn-sm(type="submit" onclick="return confirm('Hapus tiket ini dari riwayat?')" style="background: transparent; border: 1px solid var(--danger); color: var(--danger); padding: 8px 15px;") Hapus
    else
      .empty-state
        h3 Belum ada pesanan
        p Anda belum pernah memesan tiket.
        a.btn.btn-primary(href="/customer/dashboard" style="margin-top:15px;") Cari Jadwal Sekarang

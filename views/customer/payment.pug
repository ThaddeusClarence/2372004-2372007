extends ../layout-customer

block content
  .page-header
    h2 Selesaikan Pembayaran Anda
    p Kode Pemesanan: <strong>##{booking.booking_code}</strong>

  .card(style="margin-top:20px; text-align: center;")
    if booking.status === 'pending'
      h3 Segera Lakukan Pembayaran
      p Waktu Anda untuk membayar sebelum kursi otomatis dibatalkan:
      .countdown(style="font-size: 2.5em; font-weight: bold; color: var(--danger); margin: 20px 0;" id="timer") 10:00

      p Total yang harus dibayar:
      h2(style="color: var(--primary); margin-bottom: 30px;") Rp #{Number(booking.total_amount).toLocaleString('id-ID')}

      if error
        .alert.alert-danger(style="max-width: 500px; margin: 0 auto 20px; padding: 15px; border-radius: 10px; background: rgba(220,53,69,0.15); border: 1px solid var(--danger); color: var(--danger); text-align: left;")
          strong Pembayaran Gagal:
          | #{error}

      form.payment-form(method="POST" action=`/customer/pay/${booking.booking_id}` style="text-align: left; max-width: 500px; margin: 0 auto; background: rgba(255,255,255,0.03); padding: 25px; border-radius: 15px; border: 1px solid var(--border);")
        h4(style="margin-bottom: 15px;") Pilih Metode Pembayaran
        
        .form-group
          select.form-control(name="payment_method" required style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--text-main); font-family: inherit;")
            option(value="") -- Pilih Metode --
            option(value="BCA") Transfer BCA
            option(value="MANDIRI") Transfer Mandiri
            option(value="BNI") Transfer BNI
            option(value="GOPAY") GoPay
            option(value="OVO") OVO
            option(value="QRIS") QRIS
            
        .form-group(style="margin-top: 15px;")
          label(style="display: block; margin-bottom: 8px; font-size: 0.9em; color: var(--text-muted);") Nomor Rekening / No. HP (Simulasi)
          input.form-control(type="text" name="account_number" placeholder="Contoh: 08123456789" required style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--text-main); font-family: inherit;")

        .form-group(style="margin-top: 15px; margin-bottom: 25px;")
          label(style="display: block; margin-bottom: 8px; font-size: 0.9em; color: var(--text-muted);") PIN / Password (Simulasi)
          input.form-control(type="password" name="pin" placeholder="Masukkan 6 digit PIN" required style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--text-main); font-family: inherit;")

        button.btn.btn-primary(type="submit" style="width: 100%; font-size: 1.1em; padding: 15px;") Konfirmasi Pembayaran
      script.
        const holdExpiredAt = new Date("#{booking.hold_expired_at}").getTime();
        const timerEl = document.getElementById('timer');
        
        const interval = setInterval(() => {
          const now = new Date().getTime();
          const distance = holdExpiredAt - now;
          
          if (distance < 0) {
            clearInterval(interval);
            timerEl.innerHTML = "WAKTU HABIS";
            setTimeout(() => { window.location.reload(); }, 2000);
            return;
          }
          
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);
          
          timerEl.innerHTML = minutes + "m " + seconds + "s ";
        }, 1000);

    else if booking.status === 'expired'
      h3(style="color: var(--danger);") Waktu Pembayaran Habis
      p Maaf, waktu pembayaran Anda telah habis dan pemesanan otomatis dibatalkan.
      a.btn.btn-primary(href="/customer/dashboard" style="margin-top:20px;") Cari Jadwal Lagi
      
    else if booking.status === 'confirmed'
      h3(style="color: var(--success);") Pembayaran Berhasil!
      p Tiket Anda sudah aktif. Silakan lihat E-Ticket untuk detail perjalanan Anda.
      div(style="margin-top: 20px; display: flex; gap: 12px; justify-content: center;")
        a.btn.btn-primary(href=`/customer/eticket/${booking.booking_id}`) Lihat E-Ticket
        a.btn.btn-secondary(href="/customer/my-bookings") Pesanan Saya

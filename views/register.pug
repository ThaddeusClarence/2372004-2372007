extends layout

block content
  .glass-card.form-container
    h2 Daftar Akun
    if error
      p(style="color: #ef4444; text-align: center; margin-bottom: 1rem; font-size: 0.9rem;") #{error}
    form(action="/register" method="POST")
      .form-group
        label(for="email") Email
        input#email(type="email" name="email" placeholder="Masukkan email Anda" required)
      .form-group
        label(for="username") Username
        input#username(type="text" name="username" placeholder="Masukkan username Anda" required)
      .form-group
        label(for="password") Password
        input#password(type="password" name="password" placeholder="Buat password" required)
      button.btn.btn-large(type="submit" style="width: 100%") Daftar Sekarang
    p(style="text-align: center; margin-top: 1.5rem; color: var(--text-muted);") Sudah punya akun? 
      a(href="/login" style="color: var(--primary); font-weight: 600; text-decoration: none;") Masuk di sini

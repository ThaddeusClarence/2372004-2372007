doctype html
html(lang="id")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= title || 'TravelGo'
    link(rel="stylesheet" href="/css/style.css")
  body
    header
      a.logo(href="/")
        span 🚗
        span TravelGo
      nav.nav-links
        a(href="/") Home
        a(href="/login" class="btn btn-primary") Login
    main
      block content

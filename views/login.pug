extends layout

block content
  section.auth-section
    .auth-container
      .auth-info
        .brand-badge
          svg.icon-svg(width="16" height="16" viewBox="0 0 24 24" aria-hidden="true")
            path(d="M5 12l5 5l10-10")
          span TravelGo Premium
        h1
          | Selamat Datang
          br
          span Kembali!
        p
          | Masuk untuk memesan tiket perjalanan dengan cepat,
          | memilih kursi favorit, dan menikmati pengalaman travel premium.
        .auth-features
          .feature-item
            svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z")
            p Armada nyaman & modern
          .feature-item
            svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z")
            p Jadwal keberangkatan tepat waktu
          .feature-item
            svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z")
            p Pembayaran aman & terpercaya

      .auth-form-card
        h2 Masuk Ke TravelGo
        p.form-subtitle
          | Masuk dengan akun pelanggan atau administrator.

        if error
          .alert-error #{error}

        form(action="/login" method="POST")
          .form-group
            label(for="email") Email
            .input-box
              span.input-icon
                svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z")
              input#email(type="email" name="email" placeholder="Masukkan email Anda" required)

          .form-group
            label(for="password") Password
            .input-box
              span.input-icon
                svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z")
              input#password(type="password" name="password" placeholder="Masukkan password" required)

          button.btn.btn-primary.btn-large(type="submit") Masuk Sekarang

        style.
          .demo-btn {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 8px 10px;
            cursor: pointer;
            text-align: left;
            transition: all 0.2s ease;
          }
          .demo-btn:hover {
            background: rgba(255,255,255,0.08) !important;
            border-color: var(--primary) !important;
          }
          details[open] summary {
            margin-bottom: 10px;
          }

        .demo-accounts-section(style="margin-top: 20px; border-top: 1px solid var(--border); padding-top: 15px;")
          details
            summary(style="cursor: pointer; color: var(--primary); font-size: 0.85em; font-weight: 600; outline: none; user-select: none;") 💡 Klik untuk Daftar 10 Akun Uji Coba (Isi Otomatis)
            
            p(style="font-size: 0.75em; font-weight: 600; color: var(--primary); margin: 12px 0 6px 0;") 🛡️ Administrator
            .demo-grid(style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;")
              .demo-btn(onclick="fillDemo('admin@travelgo.com', 'admin123')")
                p(style="font-size: 0.75em; font-weight: 700; color: var(--text); margin: 0;") Admin Utama
                p(style="font-size: 0.65em; color: var(--text-muted); margin: 0;") admin@travelgo.com / admin123
              .demo-btn(onclick="fillDemo('admin2@travelgo.com', 'admin123')")
                p(style="font-size: 0.75em; font-weight: 700; color: var(--text); margin: 0;") Admin 2 (CS)
                p(style="font-size: 0.65em; color: var(--text-muted); margin: 0;") admin2@travelgo.com / admin123
              .demo-btn(onclick="fillDemo('admin3@travelgo.com', 'admin123')")
                p(style="font-size: 0.75em; font-weight: 700; color: var(--text); margin: 0;") Admin 3 (Finance)
                p(style="font-size: 0.65em; color: var(--text-muted); margin: 0;") admin3@travelgo.com / admin123

            p(style="font-size: 0.75em; font-weight: 600; color: var(--primary); margin: 12px 0 6px 0;") 👤 Pelanggan
            .demo-grid(style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;")
              .demo-btn(onclick="fillDemo('budi@example.com', 'cust123')")
                p(style="font-size: 0.75em; font-weight: 700; color: var(--text); margin: 0;") Budi (Lunas)
                p(style="font-size: 0.65em; color: var(--text-muted); margin: 0;") budi@example.com / cust123
              .demo-btn(onclick="fillDemo('ani@example.com', 'cust123')")
                p(style="font-size: 0.75em; font-weight: 700; color: var(--text); margin: 0;") Ani (Pending Bayar)
                p(style="font-size: 0.65em; color: var(--text-muted); margin: 0;") ani@example.com / cust123
              .demo-btn(onclick="fillDemo('candra@example.com', 'cust123')")
                p(style="font-size: 0.75em; font-weight: 700; color: var(--text); margin: 0;") Candra (Dibatalkan)
                p(style="font-size: 0.65em; color: var(--text-muted); margin: 0;") candra@example.com / cust123
              .demo-btn(onclick="fillDemo('dewi@example.com', 'cust123')")
                p(style="font-size: 0.75em; font-weight: 700; color: var(--text); margin: 0;") Dewi (Req Pembatalan)
                p(style="font-size: 0.65em; color: var(--text-muted); margin: 0;") dewi@example.com / cust123
              .demo-btn(onclick="fillDemo('eko@example.com', 'cust123')")
                p(style="font-size: 0.75em; font-weight: 700; color: var(--text); margin: 0;") Eko (Req Reschedule)
                p(style="font-size: 0.65em; color: var(--text-muted); margin: 0;") eko@example.com / cust123
              .demo-btn(onclick="fillDemo('farida@example.com', 'cust123')")
                p(style="font-size: 0.75em; font-weight: 700; color: var(--text); margin: 0;") Farida (Normal)
                p(style="font-size: 0.65em; color: var(--text-muted); margin: 0;") farida@example.com / cust123
              .demo-btn(onclick="fillDemo('gita@example.com', 'cust123')")
                p(style="font-size: 0.75em; font-weight: 700; color: var(--text); margin: 0;") Gita (Normal)
                p(style="font-size: 0.65em; color: var(--text-muted); margin: 0;") gita@example.com / cust123

        script.
          function fillDemo(email, password) {
            document.getElementById('email').value = email;
            document.getElementById('password').value = password;
          }

        .bottom-text
          p
            | Belum punya akun?
            a(href="/register") Daftar di sini

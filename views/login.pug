extends layout

block content
  section.auth-section
    .auth-container
      .auth-info
        .brand-badge
          svg.icon-svg(width="16" height="16" viewBox="0 0 24 24" aria-hidden="true")
            path(d="M5 12l5 5l10-10")
          span TravelGo Premium
        h1
          | Selamat Datang
          br
          span Kembali!
        p
          | Masuk untuk memesan tiket perjalanan dengan cepat,
          | memilih kursi favorit, dan menikmati pengalaman travel premium.
        .auth-features
          .feature-item
            svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z")
            p Armada nyaman & modern
          .feature-item
            svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z")
            p Jadwal keberangkatan tepat waktu
          .feature-item
            svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z")
            p Pembayaran aman & terpercaya

      .auth-form-card
        h2 Masuk Ke TravelGo
        p.form-subtitle
          | Masuk dengan akun pelanggan atau administrator.

        if error
          .alert-error #{error}

        form(action="/login" method="POST")
          .form-group
            label(for="email") Email
            .input-box
              span.input-icon
                svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z")
              input#email(type="email" name="email" placeholder="Masukkan email Anda" required)

          .form-group
            label(for="password") Password
            .input-box
              span.input-icon
                svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                  path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z")
              input#password(type="password" name="password" placeholder="Masukkan password" required)

          button.btn.btn-primary.btn-large(type="submit") Masuk Sekarang

        .bottom-text
          p
            | Belum punya akun?
            a(href="/register") Daftar di sini

//- CODE-CITE:
//-   Title: Login Template
//-   Type: ai
//-   Value: Antigravity Gemini
//-   Notes: UI template structure and styling helper.
//-   Lines Range: 270
extends layout

block content
  section.auth-section
    .auth-background
    .auth-container

      // LEFT SIDE
      .auth-info
        .brand-badge ✨ TravelGo Premium
        h1
          | Selamat Datang
          br
          span Kembali!
        p
          | Masuk untuk memesan tiket perjalanan dengan cepat,
          | memilih kursi favorit, dan menikmati pengalaman travel premium.
        .auth-features
          .feature-item
            span.icon 🚌
            p Armada nyaman & modern
          .feature-item
            span.icon ⏰
            p Jadwal keberangkatan tepat waktu
          .feature-item
            span.icon 🔒
            p Pembayaran aman & terpercaya

      // RIGHT SIDE
      .glass-card.form-container
        h2 Masuk Ke TravelGo
        p.form-subtitle
          | Masuk dengan akun pelanggan atau administrator.

        if error
          .alert-error
            | #{error}

        form(action="/login" method="POST")
          .form-group
            label(for="email") Email
            .input-box
              span.input-icon ✉️
              input#email(
                type="email"
                name="email"
                placeholder="Masukkan email Anda"
                required
              )

          .form-group
            label(for="password") Password
            .input-box
              span.input-icon 🔒
              input#password(
                type="password"
                name="password"
                placeholder="Masukkan password"
                required
              )

          button.btn.btn-primary.btn-large(type="submit")
            | Masuk Sekarang

        .bottom-text
          p
            | Belum punya akun?
            a(href="/register") Daftar di sini

  style.
    main {
      padding: 0 !important;
      max-width: none !important;
      margin: 0 !important;
      width: 100% !important;
    }

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      font-family:'Poppins',sans-serif;
      background:#0f172a;
    }

    .auth-section{
      min-height:100vh;
      position:relative;
      display:flex;
      align-items:center;
      justify-content:center;
      overflow:hidden;
      padding:40px;
      background:
        linear-gradient(rgba(15,23,42,.82), rgba(15,23,42,.82)),
        url('https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?q=80&w=1600&auto=format&fit=crop');
      background-size:cover;
      background-position:center;
    }

    .auth-container{
      width:100%;
      max-width:1200px;
      display:grid;
      grid-template-columns:1fr 480px;
      gap:50px;
      align-items:center;
    }

    .auth-info{
      color:white;
    }

    .brand-badge{
      display:inline-block;
      padding:10px 18px;
      border-radius:999px;
      background:rgba(255,255,255,.12);
      border:1px solid rgba(255,255,255,.18);
      margin-bottom:25px;
      backdrop-filter:blur(10px);
      font-size:.95rem;
    }

    .auth-info h1{
      font-size:4rem;
      line-height:1.2;
      margin-bottom:20px;
      font-weight:700;
    }

    .auth-info h1 span{
      color:#60a5fa;
    }

    .auth-info p{
      color:rgba(255,255,255,.82);
      line-height:1.9;
      max-width:550px;
      font-size:1.05rem;
    }

    .auth-features{
      margin-top:40px;
      display:flex;
      flex-direction:column;
      gap:20px;
    }

    .feature-item{
      display:flex;
      align-items:center;
      gap:16px;
      background:rgba(255,255,255,.08);
      border:1px solid rgba(255,255,255,.12);
      padding:18px 20px;
      border-radius:18px;
      backdrop-filter:blur(12px);
      max-width:400px;
    }

    .feature-item .icon{
      font-size:1.5rem;
    }

    .glass-card{
      background:rgba(255,255,255,.1);
      border:1px solid rgba(255,255,255,.12);
      backdrop-filter:blur(20px);
      border-radius:28px;
      padding:40px;
      box-shadow:0 20px 50px rgba(0,0,0,.25);
    }

    .form-container h2{
      color:white;
      font-size:2rem;
      margin-bottom:10px;
      text-align:center;
    }

    .form-subtitle{
      text-align:center;
      color:rgba(255,255,255,.72);
      margin-bottom:30px;
      line-height:1.7;
    }

    .alert-error{
      background:rgba(239,68,68,.15);
      border:1px solid rgba(239,68,68,.4);
      color:#fecaca;
      padding:14px;
      border-radius:14px;
      margin-bottom:22px;
      text-align:center;
      font-size:.95rem;
    }

    .form-group{
      margin-bottom:22px;
    }

    .form-group label{
      display:block;
      color:white;
      margin-bottom:10px;
      font-weight:500;
    }

    .input-box{
      position:relative;
    }

    .input-icon{
      position:absolute;
      left:16px;
      top:50%;
      transform:translateY(-50%);
      font-size:1rem;
    }

    .input-box input{
      width:100%;
      padding:16px 16px 16px 48px;
      border:none;
      outline:none;
      border-radius:16px;
      background:rgba(255,255,255,.08);
      color:white;
      font-size:1rem;
      border:1px solid rgba(255,255,255,.08);
      transition:.3s;
    }

    .input-box input::placeholder{
      color:rgba(255,255,255,.45);
    }

    .input-box input:focus{
      border-color:#60a5fa;
      background:rgba(255,255,255,.12);
    }

    .btn{
      width:100%;
      border:none;
      cursor:pointer;
      padding:16px;
      border-radius:16px;
      font-size:1rem;
      font-weight:600;
      transition:.3s;
    }

    .btn-primary{
      background:#2563eb;
      color:white;
      box-shadow:0 10px 25px rgba(37,99,235,.35);
    }

    .btn-primary:hover{
      transform:translateY(-3px);
      background:#1d4ed8;
    }

    .bottom-text{
      text-align:center;
      margin-top:28px;
      color:rgba(255,255,255,.7);
    }

    .bottom-text a{
      color:#60a5fa;
      text-decoration:none;
      font-weight:600;
      margin-left:5px;
    }

    @media(max-width:950px){
      .auth-container{
        grid-template-columns:1fr;
      }
      .auth-info{
        text-align:center;
      }
      .auth-info p{
        margin:auto;
      }
      .feature-item{
        margin:auto;
      }
      .auth-info h1{
        font-size:2.8rem;
      }
    }

    @media(max-width:600px){
      .auth-section{
        padding:20px;
      }
      .glass-card{
        padding:28px;
      }
      .auth-info h1{
        font-size:2.2rem;
      }
    }

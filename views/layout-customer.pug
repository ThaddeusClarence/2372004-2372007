doctype html
html(lang="id")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= title || 'TravelGo - Customer'
    link(rel="stylesheet" href="/css/style.css")
  body
    header
      a.logo(href="/customer/dashboard")
        svg.logo-icon-svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
          path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z")
        span TravelGo
      nav.nav-links
        a(href="/customer/dashboard") Cari Jadwal
        a(href="/customer/my-bookings") Pesanan Saya
        a(href="/logout" class="btn btn-secondary") Logout
    main
      block content

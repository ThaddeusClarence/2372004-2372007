extends layout

block content
  // =========================
  // HERO
  // =========================
  section.hero-modern
    .hero-content
      span.hero-badge
        svg.icon-svg(width="14" height="14" viewBox="0 0 24 24" aria-hidden="true")
          polyline(points="20 6 9 17 4 12")
        | Travel Premium Indonesia

      h1
        | Jelajahi Nusantara
        br
        span.highlight dengan Nyaman & Aman

      p.hero-subtitle
        | TravelGo hadir sebagai solusi perjalanan darat modern dengan armada premium,
        | jadwal tepat waktu, dan sistem reservasi online yang cepat serta praktis.

      .action-buttons
        a.btn.btn-primary.btn-large(href="/login") Mulai Perjalanan
        a.btn.btn-secondary.btn-large(href="#features") Pelajari Lebih Lanjut

      .hero-stats
        .stat-box
          h3 10K+
          p Penumpang
        .stat-box
          h3 120+
          p Armada
        .stat-box
          h3 24/7
          p Customer Support

  // =========================
  // FEATURES
  // =========================
  section#features.features-section
    .section-header
      h2 Kenapa Memilih TravelGo?
      p Kami memberikan pengalaman perjalanan terbaik dengan layanan premium dan teknologi modern.

    .features-grid
      .feature-card
        .feature-icon
          svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z")
        h3 Tepat Waktu
        p Keberangkatan selalu sesuai jadwal tanpa harus menunggu lama atau ngetem sembarangan.

      .feature-card
        .feature-icon
          svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4")
        h3 Kursi Premium
        p Nikmati kursi ergonomis dengan ruang kaki luas untuk kenyamanan maksimal selama perjalanan.

      .feature-card
        .feature-icon
          svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z")
        h3 Pilih Kursi Bebas
        p Tentukan posisi duduk favorit Anda secara real-time saat melakukan pemesanan online.

      .feature-card
        .feature-icon
          svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z")
        h3 Aman & Terpercaya
        p Driver profesional dan armada yang selalu rutin dicek demi keamanan perjalanan Anda.

      .feature-card
        .feature-icon
          svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z")
        h3 Pembayaran Mudah
        p Mendukung berbagai metode pembayaran digital dengan proses cepat dan aman.

      .feature-card
        .feature-icon
          svg(aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z")
        h3 Banyak Pilihan Rute
        p Tersedia berbagai rute populer antar kota dengan jadwal yang fleksibel.

  // =========================
  // POPULAR ROUTES
  // =========================
  section.routes-section
    .section-header
      h2 Rute Perjalanan Terpopuler
      p Pilihan rute favorit pelanggan TravelGo setiap harinya.

    .routes-grid
      .route-card
        .route-image(style="background: linear-gradient(135deg, #1a0a0e, #2d1418);")
        .route-overlay
        .route-info
          h3 Jakarta → Bandung
          p Executive Class
          span.price Mulai dari Rp 150.000

      .route-card
        .route-image(style="background: linear-gradient(135deg, #0f111a, #1a1428);")
        .route-overlay
        .route-info
          h3 Surabaya → Malang
          p Premium Class
          span.price Mulai dari Rp 100.000

      .route-card
        .route-image(style="background: linear-gradient(135deg, #1a0a0e, #2d1418);")
        .route-overlay
        .route-info
          h3 Semarang → Yogyakarta
          p Executive Class
          span.price Mulai dari Rp 120.000

  // =========================
  // CTA
  // =========================
  section.cta-section
    .cta-card
      h2 Siap Untuk Perjalanan Berikutnya?
      p Bergabunglah bersama ribuan penumpang lainnya yang mempercayakan perjalanannya kepada TravelGo.
      a.btn.btn-primary.btn-large(href="/login") Daftar / Masuk Sekarang
